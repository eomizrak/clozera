{
  "name": "clozera-backend",
  "version": "0.1.0",
  "private": true,
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "node ./bin/www",
    "dev": "nodemon ./bin/www",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "test": "NODE_ENV=test DOTENV_CONFIG_PATH=./.env.test.local jest --runInBand --testPathIgnorePatterns=/integration/",
    "test:watch": "NODE_ENV=test DOTENV_CONFIG_PATH=./.env.test.local jest --watch --testPathIgnorePatterns=/integration/",
    "test:coverage": "NODE_ENV=test DOTENV_CONFIG_PATH=./.env.test.local jest --coverage --runInBand --testPathIgnorePatterns=/integration/",
    "test:debug": "NODE_ENV=test DOTENV_CONFIG_PATH=./.env.test.local jest --runInBand --detectOpenHandles --testPathIgnorePatterns=/integration/",
    "test:integration": "NODE_ENV=test DOTENV_CONFIG_PATH=./.env.test.local jest --runInBand src/__tests__/integration",
    "test:all": "NODE_ENV=test DOTENV_CONFIG_PATH=./.env.test.local jest --runInBand"
  },
  "keywords": [],
  "author": "",
  "license": "GPL-3.0-only",
  "type": "commonjs",
  "dependencies": {
    "axios": "^1.15.0",
    "connect-mongo": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "debug": "^4.4.3",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "http-errors": "^2.0.1",
    "mongoose": "^9.4.1",
    "mongoose-autopopulate": "^1.2.1",
    "morgan": "^1.10.1",
    "passport": "^0.7.0",
    "passport-local-mongoose": "^9.0.1",
    "pug": "^3.0.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2"
  }
}
