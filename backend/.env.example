# Server
NODE_ENV=development
PORT=3000

# Database
# Use localhost for running MongoDB directly on your machine.
MONGODB_CONNECTION_STRING=mongodb://localhost:27017/clozera

# If you run the backend with Docker Compose and the Mongo service is named
# "mongodb", use this instead:
# MONGODB_CONNECTION_STRING=mongodb://mongodb:27017/clozera

# MongoDB Atlas example:
# Replace every placeholder and URL-encode special characters in the password.
# MONGODB_CONNECTION_STRING=mongodb+srv://<username>:<password>@<cluster-host>/clozera?retryWrites=true&w=majority&appName=clozera

# Client / CORS
FRONTEND_URL=http://localhost:5173

# Sessions
SESSION_SECRET=change-me-to-a-long-random-string

# External APIs
#OPENAI_API_KEY=your-openai-key-here
